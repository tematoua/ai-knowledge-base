# DeepSeek API配置
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 模型配置
LLM_MODEL=deepseek-chat
EMBEDDING_MODEL=text-embedding-3-small

# 向量数据库配置
CHROMA_PERSIST_DIRECTORY=./chroma_db

# ========== 内置知识库配置 ==========
# BUILTIN_KB_ENABLED: 是否启用内置知识库 (true/false)
BUILTIN_KB_ENABLED=true
# BUILTIN_KB_AUTO_INIT: 启动时自动初始化内置知识库 (true/false)
BUILTIN_KB_AUTO_INIT=true
# BUILTIN_KB_FORCE_INIT: 每次启动强制重建内置知识库 (true/false)
BUILTIN_KB_FORCE_INIT=false

# ========== Day 4 检索优化配置 ==========

# 文本切分配置
# chunk_size: 每块最大字符数（建议1000，太小会碎片太多，太大检索不精准）
CHUNK_SIZE=1000
# chunk_overlap: 相邻块重叠字符数（建议100-200，保证上下文连贯）
CHUNK_OVERLAP=100

# 检索配置
# RETRIEVAL_TOP_K: 检索返回的最大结果数（建议5，太少召回不足，太多噪音大）
RETRIEVAL_TOP_K=5
# RETRIEVAL_SCORE_THRESHOLD: 相似度分数阈值（0-1之间，中文模型建议0.3-0.5）
# 低于此分数的结果会被过滤掉，避免召回不相关内容
RETRIEVAL_SCORE_THRESHOLD=0.3

# Rerank配置（可选，默认关闭）
# USE_RERANK: 是否启用重排序（true/false）
# 开启后会基于关键词匹配频率对检索结果重新排序，提升相关性
USE_RERANK=false
# RERANK_TOP_K: 重排序后保留的结果数（必须 <= RETRIEVAL_TOP_K）
RERANK_TOP_K=3
